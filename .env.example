# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FEATHERLESS_API_KEY: Featherless AI Platform API Key for DeepSeek V3.2
FEATHERLESS_API_KEY="your_actual_featherless_api_key_here"
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"

# MONGODB_URI: Connection string for your MongoDB database
MONGODB_URI=

# GEMINI_API_KEY: Google Gemini API Key
GEMINI_API_KEY=

# AUTH_SECRET: Random 32-character string for signing JWTs
AUTH_SECRET=
# AUTH_GOOGLE_ID: Google Cloud OAuth Client ID
AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET: Google Cloud OAuth Client Secret
AUTH_GOOGLE_SECRET=

# Gmail SMTP Setup (Custom Email Verification)
GMAIL_USER=
GMAIL_APP_PASSWORD=
CRON_SECRET=
VITE_ADMIN_EMAILS=
